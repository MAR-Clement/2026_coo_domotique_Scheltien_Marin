@startuml
class Hifi{
-son : int
+toString()
}

class Television{
-son : int
+toString()
}

Interface Appareil{
+AllumerAppareil()
+EteindreAppareil()
+Augmenter()
+Baisser()
}

class Telecommande{
-appareils : List<Object>
-lampes: Lampe[]
-hifis: Hifi[]
+ajouterAppareil()
}

class Lampe{
-nom: String
+toString()
}

Appareil"1..*" <-up- Telecommande
Appareil <|... Hifi
Appareil <|... Lampe
Appareil <|... Television
@enduml
